#!/bin/bash

search_type="repos"

_curl_gh() {
    local url="$1"
    local max_retries=3
    local attempt=0
    while (( attempt < max_retries )); do
        local result
        result=$(curl -s --connect-timeout 10 --max-time 30 -H "Accept: application/vnd.github.v3+json" -w "\n%{http_code}" "$url" 2>/dev/null)
        local http_code="${result##*$'\n'}"
        if [[ "$http_code" == "200" ]]; then
            printf '%s' "${result%$'\n'*}"
            return 0
        elif [[ "$http_code" == "000" ]]; then
            ((attempt++))
            sleep 1
        else
            printf '%s' "$http_code"
            return 1
        fi
    done
    printf '%s' "000"
    return 1
}

_count_lines() { local c=0; while read -r l; do ((c++)); done; printf '%s' "$c"; }
_get_nth_line() { local d="$1" n="$2" i=0; while IFS= read -r l; do ((i++)); [[ $i -eq $n ]] && printf '%s' "$l" && return; done <<< "$d"; }
_get_field() { local l="$1" f="$2" IFS="|"; set -- $l; eval "printf '%s' \$$f"; }

gitsearch() {
    search_type="repos"
    local query="" lang="" num=15
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -u|--user) search_type="users"; shift ;;
        -n|--num) num="$2"; shift 2 ;;
        *) [[ -z "$query" ]] && query="$1" || lang="$1"; shift ;;
        esac
    done
    [[ -z "$query" ]] && printf "Usage: gitsearch [-u|--user] [-n NUM] <term> [lang]\n" && return
    query="${query// /%20}"
    local url="https://api.github.com/search/repositories?q=${query}"
    [[ -n "$lang" ]] && url+="+language:${lang}"
    url+="&per_page=$num"
    printf "\033[1;34mSearching GitHub repos: \033[32m%s\033[0m\n" "$query"
    local res=$(_curl_gh "$url")
    [[ $? -ne 0 ]] && printf "Error: %s\n" "$res" && return
    local items=$(echo "$res" | jq -r '.items[] | "\(.full_name // .login)"' 2>/dev/null)
    [[ -z "$items" ]] && printf "No repos found.\n" && return
    local c=0 name desc stars lang
    while IFS="|" read -r name desc stars lang; do
        ((c++))
        printf "\033[1;33m[%s]\033[0m \033[1;32m%s\033[0m (\033[1;36m%s★\033[0m) [\033[90m%s\033[0m]\n    %s\n" "$c" "$name" "$stars" "$lang" "$desc"
    done <<< "$items"
    printf "\033[1;90mEnter number (1-%s) or c: \033[0m" "$c"
    read -r ch
    [[ "$ch" == [cC] ]] && return
    if [[ "$ch" =~ ^[0-9]+$ ]] && (( ch >= 1 && ch <= c )); then
        local sel=$(_get_nth_line "$items" "$ch")
        local repos_name=$(_get_field "$sel" 1)
        printf "\n\033[1;34mRepository: \033[1;32m%s\033[0m\n" "$repos_name"
        local detail=$(_curl_gh "https://api.github.com/repos/${repos_name}")
        [[ $? -eq 0 ]] && echo "$detail" | jq -r '.description, .stargazers_count, .language, .forks_count'
        printf "\033[1;90mClone this repository? [y/n]: \033[0m"
        read -r confirm
        [[ "$confirm" == [yY] ]] && git clone "https://github.com/$repos_name.git" &
    fi
}

gitsearch "$@"
