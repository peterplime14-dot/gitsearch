#!/usr/bin/env bash

gitsearch_macOS() {
    local search_type="repos"
    local query=""
    local lang=""
    local num=15
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -u|--user)
                search_type="users"
                shift
                ;;
            -n|--num)
                num="${2:-15}"
                shift 2
                ;;
            *)
                if [[ -z "$query" ]]; then
                    query="$1"
                else
                    lang="$1"
                fi
                shift
                ;;
        esac
    done
    
    [[ -z "$query" ]] && printf "Usage: gitsearch [-u|--user] [-n NUM] <term> [lang]\n  -u, --user: Search for users instead of repos\n  -n, --num:  Number of results (default: 15)\n" && return
    
    query="${query// /%20}"

    if command -v python3 >/dev/null 2>&1; then
        local PYTHON_CMD="python3"
    elif command -v python >/dev/null 2>&1; then
        local PYTHON_CMD="python"
    else
        printf "\033[1;31mPython not found. Install with: brew install python\033[0m\n" 
        return 1
    fi

_curl_gh() {
    local url="$1"
    local max_retries=3
    local attempt=0
    local result http_code
    
    while (( attempt < max_retries )); do
        result=$(curl -s --connect-timeout 10 --max-time 30 -H "Accept: application/vnd.github.v3+json" -w "\n%{http_code}" "$url" 2>/dev/null)
        http_code=$(echo "$result" | tail -1)
        
        if [[ "$http_code" == "200" ]]; then
            echo "$result" | sed '$d'
            return 0
        elif [[ "$http_code" == "000" ]]; then
            ((attempt++))
            sleep 1
        else
            break
        fi
    done
    
    echo "$http_code"
    return 1
}

_fetch_users_parallel() {
    local users_json="$1"
    local pids=()
    local results=()
    
    while IFS='|' read -r idx login url; do
        local tmpfile="/tmp/gs_u_${idx}_$$"
        ( curl -s --connect-timeout 5 --max-time 15 -H "Accept: application/vnd.github.v3+json" "https://api.github.com/users/${login}" > "$tmpfile" 2>&1 ) &
        pids+=($!)
        results+=("$idx|$login|$tmpfile|$url")
    done <<< "$users_json"
    
    local user_profiles=""
    for i in "${!pids[@]}"; do
        wait "${pids[$i]}" 2>/dev/null
        
        local idx login file url repo_count
        IFS='|' read -r idx login file url <<< "${results[$i]}"
        
        repo_count="?"
        if [[ -f "$file" ]]; then
            repo_count=$($PYTHON_CMD -c "
import sys, json
try:
    print(json.load(open('${file}')).get('public_repos', 0))
except: print('?')" 2>/dev/null)
            command rm -f "$file"
        fi
        user_profiles+="${idx}|${login}|${repo_count}|${url}"$'\n'
    done
    echo "$user_profiles"
}

if [[ "$search_type" == "users" ]]; then
        local url="https://api.github.com/search/users?q=${query}&per_page=$num"
        
        printf "\033[1;34mSearching GitHub users: \033[32m%s\033[0m\n" "$query"
        
        local result http_code
        result=$(_curl_gh "$url")
        http_code=$?
        
        if [[ "$http_code" != "0" ]]; then
            printf "\033[1;31mHTTP Error: %s\033[0m\n" "$result"
            [[ "$result" == "403" ]] && printf "\033[1;90mRate limited. Try again later or use a token.\033[0m\n"
            [[ "$result" == "000" ]] && printf "\033[1;90mConnection failed. Retrying...\033[0m\n"
            return
        fi
        
        local users_json=$(echo "$result" | $PYTHON_CMD -c "
import sys, json
items = json.load(sys.stdin).get('items', [])
for i, item in enumerate(items, 1):
    login = item.get('login', '?')
    url = item.get('html_url', '')
    print(f'{i}|{login}|{url}')" 2>/dev/null)
        
        if [[ -z "$users_json" ]]; then
            printf "\033[1;31mNo users found.\033[0m\n"
            return
        fi
        
        local user_profiles=$(_fetch_users_parallel "$users_json")
        
        while IFS='|' read -r idx login repo_count url; do
            [[ -z "$idx" ]] && continue
            printf "\033[1;33m[%s]\033[0m \033[1;32m%s\033[0m \033[90m(%s repos)\033[0m\n    %s\n" "$idx" "$login" "$repo_count" "$url"
        done <<< "$user_profiles"
        
        echo ""
        printf "\033[1;90mEnter number (1-%s) to open, or c to cancel: \033[0m" "$(echo "$user_profiles" | wc -l)"
        read -r choice
        
        [[ "$choice" == [cC] ]] && printf "\033[1;90mCancelled.\033[0m\n" && return
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= $(echo "$user_profiles" | wc -l) )); then
            local selected_user=$(echo "$user_profiles" | sed -n "${choice}p" | cut -d'|' -f2)
            printf "\033[1;34mFetching repos for: \033[32m%s\033[0m\n" "$selected_user"
            
            local user_result http_code
            user_result=$(_curl_gh "https://api.github.com/users/${selected_user}/repos?sort=updated&per_page=$num")
            http_code=$?
            
            if [[ "$http_code" != "0" ]]; then
                printf "\033[1;31mFailed to fetch repos. HTTP: %s\033[0m\n" "$user_result"
                return
            fi
            
            local user_repos_json=$(echo "$user_result" | $PYTHON_CMD -c "
import sys, json
for i, item in enumerate(json.load(sys.stdin), 1):
    desc = ((item.get('description') or '')[:55] or 'No description')
    stars = item.get('stargazers_count', 0)
    name = item.get('full_name', '?')
    lang = item.get('language') or '-'
    print(f'{i}|{name}|{desc}|{stars}|{lang}')" 2>/dev/null)
            
            if [[ -z "$user_repos_json" ]]; then
                printf "\033[1;31mNo public repos found.\033[0m\n"
                return
            fi
            
            local user_count=$(echo "$user_repos_json" | wc -l)
            
            echo ""
            while IFS='|' read -r idx name desc stars lang; do
                printf "\033[1;33m[%s]\033[0m \033[1;32m%s\033[0m (\033[1;36m%s★\033[0m) \033[90m[%s]\033[0m\n    %s...\n" "$idx" "$name" "$stars" "$lang" "$desc"
            done <<< "$user_repos_json"
            
            echo ""
            printf "\033[1;90mEnter number (1-%s) to view details, or c to cancel: \033[0m" "$user_count"
            read -r choice
            
            [[ "$choice" == [cC] ]] && printf "\033[1;90mCancelled.\033[0m\n" && return
            
            if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= user_count )); then
                local selected=$(echo "$user_repos_json" | sed -n "${choice}p")
                local reponame=$(echo "$selected" | cut -d'|' -f2)
                local desc=$(echo "$selected" | cut -d'|' -f3)
                local stars=$(echo "$selected" | cut -d'|' -f4)
                local lang=$(echo "$selected" | cut -d'|' -f5)
                
                printf "\n\033[1;34mRepository:\033[0m \033[1;32m%s\033[0m\n" "$reponame"
                printf "\033[1;34mStars:\033[0m %s ★\n" "$stars"
                printf "\033[1;34mLanguage:\033[0m %s\n" "$lang"
                printf "\033[1;34mDescription:\033[0m %s\n" "$desc"
                
                echo ""
                printf "\033[1;90mClone this repository? [y/n]: \033[0m"
                read -r confirm
                [[ "$confirm" == [yY] ]] && git clone "https://github.com/$reponame.git" &
            fi
        fi
    else
        local url="https://api.github.com/search/repositories?q=${query}"
        [[ -n "$lang" ]] && url+="+language:${lang}"
        url+="&per_page=$num"
        
        printf "\033[1;34mSearching GitHub repos: \033[32m%s\033[0m\n" "$query"
        
        local result http_code
        result=$(_curl_gh "$url")
        http_code=$?
        
        if [[ "$http_code" != "0" ]]; then
            printf "\033[1;31mHTTP Error: %s\033[0m\n" "$result"
            [[ "$result" == "403" ]] && printf "\033[1;90mRate limited. Try again later or use a token.\033[0m\n"
            [[ "$result" == "000" ]] && printf "\033[1;90mConnection failed. Retrying...\033[0m\n"
            return
        fi
        
        local repos_json=$(echo "$result" | $PYTHON_CMD -c "
import sys, json
for i, item in enumerate(json.load(sys.stdin).get('items', []), 1):
    desc = ((item.get('description') or '')[:55] or 'No description')
    lang = item.get('language') or '-'
    print(f'{i}|{item.get(\"full_name\", \"?\")}|{desc}|{item.get(\"stargazers_count\", 0)}|{lang}')" 2>/dev/null)
        
        if [[ -z "$repos_json" ]]; then
            printf "\033[1;31mNo repos found.\033[0m\n"
            return
        fi
        
        local count=$(echo "$repos_json" | wc -l)
        
        echo ""
        while IFS='|' read -r idx name desc stars lang; do
            printf "\033[1;33m[%s]\033[0m \033[1;32m%s\033[0m (\033[1;36m%s★\033[0m) \033[90m[%s]\033[0m\n    %s...\n" "$idx" "$name" "$stars" "$lang" "$desc"
        done <<< "$repos_json"
        
        echo ""
        printf "\033[1;90mEnter number (1-%s) to view details, or c to cancel: \033[0m" "$count"
        read -r choice
        
        [[ "$choice" == [cC] ]] && printf "\033[1;90mCancelled.\033[0m\n" && return
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= count )); then
            local selected=$(echo "$repos_json" | sed -n "${choice}p")
            local reponame=$(echo "$selected" | cut -d'|' -f2)
            local desc=$(echo "$selected" | cut -d'|' -f3)
            local stars=$(echo "$selected" | cut -d'|' -f4)
            local lang=$(echo "$selected" | cut -d'|' -f5)
            
            printf "\n\033[1;34mRepository:\033[0m \033[1;32m%s\033[0m\n" "$reponame"
            printf "\033[1;34mStars:\033[0m %s ★\n" "$stars"
            printf "\033[1;34mLanguage:\033[0m %s\n" "$lang"
            printf "\033[1;34mDescription:\033[0m %s\n" "$desc"
            
            local detail_result=$(_curl_gh "https://api.github.com/repos/${reponame}")
            if [[ $? -eq 0 ]]; then
                local extra_info=$(echo "$detail_result" | $PYTHON_CMD -c "
import sys, json
repo = json.load(sys.stdin)
print(f\"Forks: {repo.get('forks_count', 0)}\")
print(f\"Watchers: {repo.get('watchers_count', 0)}\")
print(f\"Language: {repo.get('language', '-')}\")
print(f\"License: {repo.get('license', {}).get('name', '-')}\")
print(f\"Created: {repo.get('created_at', '-')[:10]}\")
print(f\"Updated: {repo.get('updated_at', '-')[:10]}\")
print(f\"URL: {repo.get('html_url', '-')}\")
" 2>/dev/null)
                echo "$extra_info"
            fi
            
            echo ""
            printf "\033[1;90mClone this repository? [y/n]: \033[0m"
            read -r confirm
            [[ "$confirm" == [yY] ]] && git clone "https://github.com/$reponame.git" &
        fi
    fi
}

gitsearch_macOS "$@"